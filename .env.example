# Ochi Environment Variables
# Copy this file to .env and fill in your values.
# Only set the providers you plan to use.

# ─── LLM Provider API Keys ───────────────────────────────────────────

# Anthropic (Claude models)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GEMINI_API_KEY=AIza...
# GOOGLE_API_KEY=AIza...          # Alternative to GEMINI_API_KEY

# OpenAI
# OPENAI_API_KEY=sk-...

# Groq (fast inference)
# GROQ_API_KEY=gsk_...

# DeepSeek
# DEEPSEEK_API_KEY=sk-...

# OpenRouter (multi-provider gateway)
# OPENROUTER_API_KEY=sk-or-...

# Together AI
# TOGETHER_API_KEY=...

# Mistral AI
# MISTRAL_API_KEY=...

# Fireworks AI
# FIREWORKS_API_KEY=...

# ─── Additional Cloud LLM Providers ──────────────────────────────────────────

# Cerebras (ultra-fast wafer-scale inference — great LLM backup)
# CEREBRAS_API_KEY=csk-...

# Perplexity AI
# PERPLEXITY_API_KEY=pplx-...

# Cohere
# COHERE_API_KEY=...

# AI21 Labs
# AI21_API_KEY=...

# SambaNova
# SAMBANOVA_API_KEY=...

# Hugging Face
# HUGGINGFACE_API_KEY=hf_...

# xAI (Grok)
# XAI_API_KEY=xai-...

# Replicate
# REPLICATE_API_KEY=r8_...

# OpenRouter (multi-provider gateway — access 200+ models with one key)
# already listed above, see OPENROUTER_API_KEY

# ─── Local LLM Providers (no API key needed) ─────────────────────────

# Ollama (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# vLLM (default: http://localhost:8000)
# VLLM_BASE_URL=http://localhost:8000

# LM Studio (default: http://localhost:1234)
# LMSTUDIO_BASE_URL=http://localhost:1234

# ─── Channel Tokens ──────────────────────────────────────────────────

# Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC-...

# Discord
# DISCORD_BOT_TOKEN=...

# Slack
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# WhatsApp (via Cloud API)
# WHATSAPP_TOKEN=...
# WHATSAPP_PHONE_ID=...

# Signal
# SIGNAL_CLI_PATH=/usr/local/bin/signal-cli
# SIGNAL_PHONE_NUMBER=+1...

# Matrix
# MATRIX_HOMESERVER=https://matrix.org
# MATRIX_ACCESS_TOKEN=...

# Email (IMAP/SMTP)
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_USERNAME=...
# EMAIL_PASSWORD=...

# ─── Ochi Configuration ──────────────────────────────────────────────

# API server bind address (default: 127.0.0.1:3000)
# OCHI_LISTEN=127.0.0.1:3000
# OPENFANG_LISTEN=127.0.0.1:3000   # legacy alias (backward-compat)

# API key for HTTP authentication (leave empty for localhost-only access)
# OCHI_API_KEY=
# OPENFANG_API_KEY=               # legacy alias (backward-compat)

# Home directory (default: ~/.ochi)
# OCHI_HOME=~/.ochi
# OPENFANG_HOME=~/.openfang      # legacy alias (backward-compat)

# Log level (default: info)
# RUST_LOG=info
# RUST_LOG=ochi=debug            # Debug Ochi only
# RUST_LOG=openfang=debug        # legacy logger target (backward-compat)
