# =============================================================
# Ochi — .gitignore
# Những file/thư mục này sẽ KHÔNG được Git theo dõi
# =============================================================

# ── Rust build artifacts ──────────────────────────────────────
/target
**/*.rs.bk
*.pdb

# ── Môi trường & bí mật (QUAN TRỌNG: không bao giờ commit!) ──
.env
.env.*
!.env.example
*.secret
secrets/

# ── Cơ sở dữ liệu cục bộ ─────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── Cấu hình người dùng (có thể chứa API key) ────────────────
config.toml

# ── Chứng chỉ & khóa bảo mật ─────────────────────────────────
*.pem
*.key
*.cert
*.p12
*.pfx
*.crt

# ── File runtime tạm thời ────────────────────────────────────
collector_hand_state.json
collector_knowledge_base.json
predictions_database.json
prediction_report_*.md
BUILD_LOG.md

# ── Node.js (packages/whatsapp-gateway, sdk/javascript) ──────
node_modules/
npm-debug.log*
yarn-debug.log*
.pnpm-debug.log*
dist/

# ── Python (sdk/python) ───────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
*.egg-info/
.pytest_cache/

# ── Hệ điều hành ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ── IDE & công cụ lập trình ───────────────────────────────────
.idea/
.vscode/
*.code-workspace
.claude/
*.swp
*.swo
*~
.direnv/

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Tài nguyên lớn / media (dùng Git LFS nếu cần) ─────────────
# Các file ảnh lớn không nên commit trực tiếp vào repo.
# Dùng Git LFS hoặc lưu trữ ngoài (CDN, object storage).
public/assets/*.png
public/assets/*.jpg
public/assets/*.jpeg
public/assets/*.gif
public/assets/*.webp
public/assets/*.svg

# ── Tauri: file sinh tự động khi build (KHÔNG commit) ─────────
# Các file này được tạo bởi `tauri build` / `tauri dev`.
# Chúng sẽ được tự động tái tạo — không cần theo dõi bằng Git.
crates/ochi-desktop/gen/
crates/openfang-desktop/gen/

# ── Cargo: profile-specific override files ────────────────────
.cargo/credentials.toml
